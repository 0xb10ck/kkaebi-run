# Godot 4+ specific ignores
.godot/
.import/

# Local export config and build outputs
export.cfg
builds/

# Imported translations generated from CSV files
*.translation

# Godot auto-generated UID files
*.gd.uid

# QA runner auto-generated reports — regenerated on every run, do not track.
# Use tests/REPORT.md as the stable, manually-maintained report.
tests/qa_report.json
tests/qa_report.md

# Python virtualenv & bytecode caches
.venv/
__pycache__/
*.pyc

# Art pipeline local cache (regenerated on each build)
assets/.art_cache.json
