[resource]
script = ExtResource("1_data")
id = &"earthquake"
display_name_ko = "대지의 진동"
description_ko = "캐릭터가 발을 굴러 화면 전체에 지진을 일으킵니다. 1차 충격파로 모든 적에게 피해와 스턴을 적용하고(보스는 둔화), 균열에서 솟구치는 15개의 돌기둥이 3초간 다단 타격을 가합니다."
element = 5
rarity = 2
trigger_mode = 1
scene = ExtResource("3_scene")
icon_color = Color(0.55, 0.40, 0.25, 1)
max_level = 5
levels = Array[Resource]([SubResource("lvl1_earthquake"), SubResource("lvl2_earthquake"), SubResource("lvl3_earthquake"), SubResource("lvl4_earthquake"), SubResource("lvl5_earthquake")])
min_chapter_to_offer = 5
synergy_partners = Array[StringName]([&"landslide", &"earth_wall"])
counter_partners = Array[StringName]([])
evolution_targets = Array[StringName]([])
unlock_condition = "5챕터를 클리어한 회차 이후부터 등장합니다."
