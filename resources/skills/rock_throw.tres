[resource]
script = ExtResource("1_data")
id = &"rock_throw"
display_name_ko = "바위 투척"
description_ko = "가장 먼 적을 향해 포물선으로 큰 바위를 던집니다. 낙하 지점 범위에 피해를 주고 짧은 스턴을 겁니다. 보스는 스턴 면역으로 둔화로 대체됩니다."
element = 5
rarity = 0
trigger_mode = 0
