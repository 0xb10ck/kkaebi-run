min_chapter_to_offer = 1
synergy_partners = Array[StringName]([&"flint_burst", &"earth_wall"])
counter_partners = Array[StringName]([&"water_drop"])
evolution_targets = Array[StringName]([&"lava_eruption"])
unlock_condition = "1챕터에서 처음부터 등장합니다."
