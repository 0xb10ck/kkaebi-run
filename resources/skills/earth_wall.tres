[resource]
script = ExtResource("1_data")
id = &"earth_wall"
display_name_ko = "흙벽"
description_ko = "캐릭터 정면에 흙벽을 생성하여 적과 투사체를 차단합니다. 벽이 부서질 때 광범위 폭발과 넉백이 발생합니다. HP가 60% 이하일 때 우선 발동됩니다."
element = 5
rarity = 0
trigger_mode = 3
scene = ExtResource("3_scene")
icon_color = Color(0.55, 0.40, 0.25, 1)
max_level = 5
levels = Array[Resource]([SubResource("lvl1_earth_wall"), SubResource("lvl2_earth_wall"), SubResource("lvl3_earth_wall"), SubResource("lvl4_earth_wall"), SubResource("lvl5_earth_wall")])
min_chapter_to_offer = 1
synergy_partners = Array[StringName]([&"gold_shield", &"rock_throw"])
counter_partners = Array[StringName]([&"water_drop"])
evolution_targets = Array[StringName]([&"iron_citadel", &"mud_swamp", &"magma_armor"])
unlock_condition = "1챕터에서 처음부터 등장합니다."
