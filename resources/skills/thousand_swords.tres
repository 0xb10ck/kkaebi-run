[resource]
script = ExtResource("1_data")
id = &"thousand_swords"
display_name_ko = "천검의 강림"
description_ko = "하늘에서 거대한 검들이 무작위/엘리트 우선으로 차례로 떨어집니다. 검 낙하 지점은 0.3초 전 노란 마커로 표시되고, 엘리트와 보스에게는 크리티컬이 확정 적용됩니다."
element = 4
rarity = 2
trigger_mode = 1
scene = ExtResource("3_scene")
icon_color = Color(0.98, 0.98, 0.85, 1)
max_level = 5
levels = Array[Resource]([SubResource("lvl1_thousand_swords"), SubResource("lvl2_thousand_swords"), SubResource("lvl3_thousand_swords"), SubResource("lvl4_thousand_swords"), SubResource("lvl5_thousand_swords")])
